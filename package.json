{
  "name": "capacitor-clerk",
  "version": "0.2.1",
  "description": "Clerk authentication for Capacitor",
  "type": "module",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./react": {
      "types": "./dist/esm/react/index.d.ts",
      "import": "./dist/esm/react/index.js"
    },
    "./token-cache": {
      "types": "./dist/esm/token-cache/index.d.ts",
      "import": "./dist/esm/token-cache/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ],
  "author": "Robert Soriano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wobsoriano/capacitor-clerk.git"
  },
  "bugs": {
    "url": "https://github.com/wobsoriano/capacitor-clerk/issues"
  },
  "keywords": [
    "capacitor",
    "clerk",
    "authentication",
    "react",
    "headless"
  ],
  "scripts": {
    "verify": "npm run lint && npm run test && npm run build",
    "lint": "npm run eslint && npm run prettier -- --check",
    "fmt": "npm run eslint -- --fix && npm run prettier -- --write",
    "eslint": "eslint . --ext ts,tsx",
    "prettier": "prettier \"**/*.{css,html,ts,tsx,js}\"",
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "release": "bumpp && npm publish"
  },
  "dependencies": {
    "@clerk/clerk-js": "^6.0.0",
    "@clerk/react": "^6.0.0",
    "@clerk/shared": "^4.0.0"
  },
  "devDependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.1",
    "@ionic/eslint-config": "^0.4.0",
    "@ionic/prettier-config": "^4.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "bumpp": "^11.0.1",
    "eslint": "^8.57.1",
    "happy-dom": "^15.0.0",
    "prettier": "^3.6.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rimraf": "^6.1.0",
    "rollup": "^4.53.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@aparajita/capacitor-secure-storage": ">=8.0.0",
    "@capacitor/app": ">=8.0.0",
    "@capacitor/browser": ">=8.0.0",
    "@capacitor/core": ">=8.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@capacitor/app": {
      "optional": true
    },
    "@capacitor/browser": {
      "optional": true
    }
  },
  "prettier": "@ionic/prettier-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  }
}
