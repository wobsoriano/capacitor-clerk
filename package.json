{
  "name": "capacitor-clerk",
  "version": "0.8.3",
  "description": "Clerk authentication for Capacitor apps, with native UI components",
  "keywords": [
    "authentication",
    "capacitor",
    "clerk",
    "headless",
    "react"
  ],
  "bugs": {
    "url": "https://github.com/wobsoriano/capacitor-clerk/issues"
  },
  "license": "MIT",
  "author": "Robert Soriano",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wobsoriano/capacitor-clerk.git"
  },
  "files": [
    "dist/",
    "ios/",
    "android/",
    "Package.swift"
  ],
  "type": "module",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.mts",
      "import": "./dist/react/index.mjs"
    },
    "./apple": {
      "types": "./dist/apple/index.d.mts",
      "import": "./dist/apple/index.mjs"
    },
    "./token-cache": {
      "types": "./dist/token-cache/index.d.mts",
      "import": "./dist/token-cache/index.mjs"
    },
    "./native": {
      "types": "./dist/native/index.d.mts",
      "import": "./dist/native/index.mjs"
    },
    "./web": {
      "types": "./dist/web/index.d.mts",
      "import": "./dist/web/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "verify": "vp check && vp test && npm run build",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "fmt": "vp fmt",
    "build": "vp pack",
    "test": "vp test run",
    "test:watch": "vp test watch",
    "prepublishOnly": "npm run build",
    "release": "bumpp && npm publish",
    "prepare": "vp config"
  },
  "dependencies": {
    "@clerk/clerk-js": "^6.7.9",
    "@clerk/react": "^6.4.7",
    "@clerk/shared": "^4.8.7"
  },
  "devDependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.1",
    "@capawesome/capacitor-apple-sign-in": "^0.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "bumpp": "^11.0.1",
    "happy-dom": "^15.11.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "peerDependencies": {
    "@aparajita/capacitor-secure-storage": ">=8.0.0",
    "@capacitor/app": ">=8.0.0",
    "@capacitor/browser": ">=8.0.0",
    "@capacitor/core": ">=8.0.0",
    "@capawesome/capacitor-apple-sign-in": ">=0.1.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@aparajita/capacitor-secure-storage": {
      "optional": true
    },
    "@capawesome/capacitor-apple-sign-in": {
      "optional": true
    },
    "@capacitor/app": {
      "optional": true
    },
    "@capacitor/browser": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.13.0",
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
